// Configuração da conexão
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Nossa primeira tabela
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Product{
  id        Int      @id @default(autoincrement())
  name      String
  description String?
  price     Float
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}